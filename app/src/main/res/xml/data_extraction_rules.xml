<?xml version="1.0" encoding="utf-8"?>
<!-- 
  Android 12+ data extraction rules (Security and privacy requirement)
  This app is 100% offline and has no network connectivity, so all data is local.
-->
<data-extraction-rules>
    <!-- Allow backup of app preferences and database (local storage only) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">example.com</domain>
    </domain-config>
</data-extraction-rules>
